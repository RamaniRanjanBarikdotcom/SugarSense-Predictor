# Copy this file to .env and fill in your values
# .env is gitignored and never committed
# Only set the API key for the provider you want to use

# ── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
# CHAT_MODEL=claude
# CHAT_MODEL=claude-opus-4-7

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
# CHAT_MODEL=gpt-4o
# CHAT_MODEL=gpt-4o-mini
# CHAT_MODEL=o3
# CHAT_MODEL=o4-mini

# ── Google AI (Gemini) ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_ai_key_here
# CHAT_MODEL=gemini-2.0-flash
# CHAT_MODEL=gemini-1.5-pro
# CHAT_MODEL=gemini-1.5-flash

# ── Hugging Face ───────────────────────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here
# CHAT_MODEL=hf/meta-llama/Llama-3.1-8B-Instruct
# CHAT_MODEL=hf/mistralai/Mistral-7B-Instruct-v0.3
# CHAT_MODEL=hf/microsoft/Phi-3-mini-4k-instruct

# ── OpenRouter (access 100+ models with one key) ───────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
# CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free
# CHAT_MODEL=google/gemini-2.0-flash-exp:free
# CHAT_MODEL=mistralai/mistral-7b-instruct:free
# CHAT_MODEL=openai/gpt-4o

# ── Active model (uncomment exactly ONE) ──────────────────────────────────────
CHAT_MODEL=claude
